# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://meezo-eta.vercel.app
BACKEND_URL=https://meezo-backend-d3gw.onrender.com

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_distinct_refresh_jwt_secret_here
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=365d
REFRESH_COOKIE_NAME=nm_rt
REFRESH_COOKIE_SAMESITE=none
REFRESH_COOKIE_SECURE=true
# REFRESH_COOKIE_DOMAIN=.your-domain.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@nearme.com

# Frontend (Vite) Configuration - needed for Docker build
VITE_API_URL=http://localhost:5000
VITE_OSRM_URL=https://router.project-osrm.org
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
