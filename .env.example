# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://meezo-eta.vercel.app
BACKEND_URL=https://meezo-backend-d3gw.onrender.com

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
JWT_SECRET=your_jwt_secret_here
# Optional during secret rotation. Keep for a short transition window, then remove.
JWT_SECRET_PREVIOUS=
WEB_ACCESS_TOKEN_EXPIRES_IN=14d
MOBILE_ACCESS_TOKEN_EXPIRES_IN=180d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=mimilhamazaab51@gmail.com

# Resend Email Configuration (recommended for cloud deployments like Render)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Meezo <noreply@meezo.lk>

MANAGER_LOGIN_URL=https://www.meezo.lk/login

# Phone OTP Configuration
PHONE_OTP_LENGTH=6
PHONE_OTP_EXPIRY_MINUTES=5
PHONE_OTP_MAX_ATTEMPTS=5
PHONE_OTP_RESEND_COOLDOWN_SECONDS=45
PHONE_OTP_PEPPER=change-this-to-a-long-random-secret



# Frontend (Vite) Configuration - needed for Docker build
VITE_API_URL=https://meezo-backend-d3gw.onrender.com
VITE_OSRM_URL=https://router.project-osrm.org
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
